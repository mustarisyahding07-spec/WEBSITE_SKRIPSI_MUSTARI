    </mxCell>

    <!-- Proses Sistem: 404 -->
    <mxCell id="S2" value="Menampilkan
Halaman 404"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="30" y="178" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Proses Sistem: Tampilkan Konten -->
    <mxCell id="S3" value="Menampilkan Konten
dan Artikel Terkait"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="450" y="178" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Aksi Pelanggan: Membaca -->
    <mxCell id="A3" value="Membaca
Konten Artikel"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
