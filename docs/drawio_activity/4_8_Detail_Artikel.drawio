      <mxGeometry x="280" y="65" width="130" height="60" as="geometry"/>
    </mxCell>

    <!-- Decision: Artikel Ditemukan? -->
    <mxCell id="S1" value="Artikel
Ditemukan?"
      style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
