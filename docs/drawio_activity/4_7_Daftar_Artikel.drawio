<?xml version="1.0" ?>
<mxGraphModel background="#ffffff">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- JUDUL -->
    <mxCell id="title" value="Gambar 4.7 – Activity Diagram Daftar Artikel"
      style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="0" y="10" width="700" height="30" as="geometry"/>
    </mxCell>

    <!-- START -->
    <mxCell id="A1" value="START"
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="30" y="60" width="50" height="50" as="geometry"/>
    </mxCell>

    <!-- Aksi Pelanggan -->
    <mxCell id="A2" value="Membuka
Halaman Artikel"
      style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=20;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="110" y="60" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Proses Sistem -->
    <mxCell id="S1" value="Memuat Daftar Artikel
yang Dipublikasikan"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="280" y="60" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Aksi Pelanggan -->
    <mxCell id="A3" value="Melihat
Daftar Artikel"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="450" y="60" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Decision: Klik Artikel? -->
    <mxCell id="S2" value="Klik
Artikel?"
      style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="30" y="165" width="110" height="80" as="geometry"/>
    </mxCell>

    <!-- Aksi Pelanggan: Baca Artikel -->
    <mxCell id="A4" value="Ke Halaman
Detail Artikel"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="170" y="178" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Decision: Pindah Halaman? -->
    <mxCell id="S3" value="Pindah
Halaman?"
      style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="340" y="165" width="110" height="80" as="geometry"/>
    </mxCell>

    <!-- Aksi Pelanggan: Klik Pagination -->
    <mxCell id="A5" value="Klik Pagination"
      style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=20;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="480" y="178" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Proses Sistem -->
    <mxCell id="S4" value="Memuat Halaman
Berikutnya"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="480" y="290" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- END -->
    <mxCell id="A6" value="END"
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;fontColor=#ffffff;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="195" y="297" width="50" height="50" as="geometry"/>
    </mxCell>

    <!-- EDGES -->
    <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="A1" target="A2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="A2" target="S1" parent="1">
