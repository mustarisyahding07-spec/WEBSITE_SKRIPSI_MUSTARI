<?xml version="1.0" ?>
<mxGraphModel background="#ffffff">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- JUDUL -->
    <mxCell id="title" value="Gambar 4.3 – Activity Diagram Detail Produk"
