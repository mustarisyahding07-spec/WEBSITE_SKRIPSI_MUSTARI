<?xml version="1.0" ?>
<mxGraphModel background="#ffffff">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- JUDUL -->
    <mxCell id="title" value="Gambar 4.16 – Activity Diagram Moderasi Review"
      style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="0" y="10" width="700" height="30" as="geometry"/>
    </mxCell>

    <!-- START -->
    <mxCell id="A1" value="START"
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="30" y="60" width="50" height="50" as="geometry"/>
    </mxCell>

    <!-- Aksi Admin -->
    <mxCell id="A2" value="Membuka Halaman
Review"
      style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=20;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="110" y="60" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Database -->
    <mxCell id="D1" value="Memuat Daftar
Review"
      style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;boundedLbl=1;backgroundOutline=1;"
      vertex="1" parent="1">
      <mxGeometry x="280" y="65" width="110" height="60" as="geometry"/>
    </mxCell>

    <!-- Aksi Admin -->
    <mxCell id="A3" value="Melihat Daftar
Review"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="420" y="65" width="110" height="55" as="geometry"/>
    </mxCell>

    <!-- Decision: Pilih Aksi? -->
    <mxCell id="S1" value="Pilih
Aksi?"
      style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="560" y="55" width="100" height="80" as="geometry"/>
    </mxCell>

    <!-- === CABANG: LIHAT === -->
    <!-- Aksi Admin: Lihat Detail -->
    <mxCell id="A4" value="Melihat Detail
Review"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="30" y="187" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Proses Sistem: Tampilkan Rating -->
    <mxCell id="S2" value="Menampilkan Rating
dan Komentar"
      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="200" y="187" width="140" height="55" as="geometry"/>
    </mxCell>

    <!-- Decision: Approve? -->
    <mxCell id="S3" value="Approve
Review?"
      style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="370" y="177" width="110" height="80" as="geometry"/>
    </mxCell>

    <!-- Aksi Admin: Approve -->
    <mxCell id="A5" value="Klik
Approve"
      style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=20;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="510" y="183" width="120" height="55" as="geometry"/>
    </mxCell>

    <!-- Aksi Admin: Reject -->
    <mxCell id="A6" value="Klik
Reject"
      style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=20;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="510" y="258" width="120" height="55" as="geometry"/>
    </mxCell>

    <!-- Database: Update Status -->
    <mxCell id="D2" value="Memperbarui
Status Review"
      style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;boundedLbl=1;backgroundOutline=1;"
      vertex="1" parent="1">
      <mxGeometry x="30" y="320" width="130" height="60" as="geometry"/>
    </mxCell>

    <!-- === CABANG: HAPUS === -->
    <!-- Aksi Admin -->
    <mxCell id="A7" value="Menghapus
Review"
      style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;size=20;fillColor=#ffffff;strokeColor=#000000;"
      vertex="1" parent="1">
      <mxGeometry x="200" y="330" width="130" height="55" as="geometry"/>
    </mxCell>

    <!-- Database: Hapus -->
    <mxCell id="D3" value="Menghapus
Data Review"
      style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;boundedLbl=1;backgroundOutline=1;"
      vertex="1" parent="1">
      <mxGeometry x="360" y="335" width="120" height="60" as="geometry"/>
    </mxCell>

    <!-- END -->
    <mxCell id="A8" value="END"
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;fontColor=#ffffff;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="510" y="342" width="50" height="50" as="geometry"/>
    </mxCell>

    <!-- EDGES -->
    <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="A1" target="A2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="A2" target="D1" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="D1" target="A3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="A3" target="S1" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e5" value="Lihat" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="S1" target="A4" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="A4" target="S2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e7" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="S2" target="S3" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e8" value="Ya" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="S3" target="A5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e9" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="A5" target="D2" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e10" value="Tidak" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="S3" target="A6" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e11" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;fillColor=#000000;strokeColor=#000000;" edge="1" source="A6" target="D2" parent="1">
